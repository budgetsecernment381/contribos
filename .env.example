# ContribOS — Root environment for docker-compose
# Copy to .env and fill in values: cp .env.example .env

# =============================================================================
# GitHub OAuth App (required — create at https://github.com/settings/developers)
# =============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# =============================================================================
# JWT Secrets (required — min 32 chars each)
# Generate with: openssl rand -base64 48
# =============================================================================
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_at_least_32_characters_long

# =============================================================================
# S3-compatible Storage (required for artifact persistence)
# =============================================================================
S3_BUCKET=contribos-artifacts
S3_REGION=us-east-1

# =============================================================================
# LLM Provider Keys (at least one required for AI fix generation)
# =============================================================================
CLAUDE_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
PERPLEXITY_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=

# =============================================================================
# Encryption (required — encrypts custom/agent provider API keys at rest)
# Generate with: openssl rand -hex 32
# =============================================================================
ENCRYPTION_KEY=

# =============================================================================
# GitHub Personal Access Token (optional — for issue sync, needs repo:read scope)
# =============================================================================
GITHUB_PAT=

# =============================================================================
# Optional Configuration
# =============================================================================
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
GITHUB_WEBHOOK_SECRET=
CALLBACK_URL=http://api:3001
WORKER_URL=http://worker:8000
WORKER_SERVICE_TOKEN=
WORKER_ID=agent-worker-1
MAX_EXECUTION_TIME=600
