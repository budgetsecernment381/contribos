# === Required ===

# Database connection (use port 5433 for docker-compose, 5432 for direct)
DATABASE_URL="postgresql://contribos:contribos_dev@localhost:5433/contribos?schema=public"

# Redis connection (use port 6380 for docker-compose, 6379 for direct)
REDIS_URL="redis://localhost:6380"

# GitHub OAuth App credentials (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID="your_github_oauth_app_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_app_client_secret"
GITHUB_CALLBACK_URL="http://localhost:3000/api/v1/auth/github/callback"

# JWT secrets (min 32 characters each — generate with: openssl rand -base64 48)
JWT_SECRET="your-jwt-secret-at-least-32-characters-long"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-at-least-32-chars"

# S3-compatible storage for artifacts
S3_BUCKET="contribos-artifacts"
S3_REGION="us-east-1"

# Encryption key for provider API keys (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="generate_with_openssl_rand_hex_32_must_be_at_least_32_chars"

# === LLM Providers (at least one required) ===
CLAUDE_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_AI_API_KEY=""
PERPLEXITY_API_KEY=""
MISTRAL_API_KEY=""
GROQ_API_KEY=""
DEEPSEEK_API_KEY=""
XAI_API_KEY=""

# === Optional ===
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"
WORKER_URL="http://localhost:8000"
WORKER_SERVICE_TOKEN="generate_a_strong_random_token_here"
GITHUB_WEBHOOK_SECRET=""
GITHUB_PAT=""
