# === LLM Provider Keys (at least one required) ===
CLAUDE_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_AI_API_KEY=""
PERPLEXITY_API_KEY=""
MISTRAL_API_KEY=""
GROQ_API_KEY=""
DEEPSEEK_API_KEY=""
XAI_API_KEY=""

# === Worker Configuration ===
# URL the worker calls back to notify the API of job completion
CALLBACK_URL="http://localhost:3001"

# Service-to-service auth token (must match API's WORKER_SERVICE_TOKEN)
WORKER_SERVICE_TOKEN="generate_a_strong_random_token_here"

# Unique worker instance identifier
WORKER_ID="agent-worker-1"

# Maximum job execution time in seconds (default: 600 = 10 minutes)
MAX_EXECUTION_TIME=600

# === S3 (optional for local dev — worker can return artifacts inline) ===
S3_BUCKET="contribos-artifacts"
S3_REGION="us-east-1"
