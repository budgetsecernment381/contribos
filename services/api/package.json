{
  "name": "@contribos/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -b",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@octokit/rest": "^22.0.1",
    "@prisma/client": "^6.2.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.8.4",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.0",
    "pino": "^9.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
